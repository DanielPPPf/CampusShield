# ═══════════════════════════════════════════════════════════════════════════
# CampusShield — Variables de entorno
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas .env al repositorio.
# ═══════════════════════════════════════════════════════════════════════════

# ── PostgreSQL ───────────────────────────────────────────────────────────
POSTGRES_DB=campusshield
POSTGRES_USER=campusshield
POSTGRES_PASSWORD=change_me_postgres

# Puerto expuesto en el host (defecto: 5432)
POSTGRES_PORT=5432

# ── Redis ────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis

# Puerto expuesto en el host (defecto: 6379)
REDIS_PORT=6379

# ── Adminer (solo dev) ───────────────────────────────────────────────────
ADMINER_PORT=8080

# ── Aplicación / API (futuro backend) ────────────────────────────────────
# Clave secreta para firmar JWT — mínimo 32 caracteres aleatorios
JWT_SECRET=change_me_jwt_secret_at_least_32_chars

# Duración del access token  (ej: 15m, 1h)
JWT_ACCESS_EXPIRES=15m

# Duración del refresh token (ej: 7d)
JWT_REFRESH_EXPIRES=7d

# VAPID para Web Push (genera con: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@campusshield.unisabana.edu.co

# Claude AI
ANTHROPIC_API_KEY=
